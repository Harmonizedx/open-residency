{
  "@context": {
    "@protected": true,

    "orv": "https://openresidency.org/vocab#",

    "StateResidencyCredential": {
      "@id": "orv:StateResidencyCredential",
      "@context": {
        "@protected": true,
        "id": "@id",
        "type": "@type"
      }
    },

    "StateResident": {
      "@id": "orv:StateResident",
      "@context": {
        "@protected": true,
        "id": "@id",
        "type": "@type",

        "residentId": "orv:residentId",
        "proofOfResidence": "orv:proofOfResidence",
        "residence": {
          "@id": "orv:residence",
          "@context": {
            "@protected": true,
            "assuranceLevel": "orv:residenceAssuranceLevel",
            "method": "orv:residenceMethod",
            "unit": "orv:residenceUnit",
            "asOf": "orv:residenceAsOf"
          }
        },
        "provisional": {
          "@id": "orv:provisional",
          "@type": "http://www.w3.org/2001/XMLSchema#boolean"
        },

        "subnationalUnit": {
          "@id": "orv:subnationalUnit",
          "@context": {
            "@protected": true,
            "country": "orv:country",
            "code": "orv:code",
            "name": "orv:name",
            "level": "orv:level"
          }
        },

        "foundationalAssurance": {
          "@id": "orv:foundationalAssurance",
          "@context": {
            "@protected": true,
            "provider": "orv:provider",
            "assuranceLevel": "orv:assuranceLevel",
            "subjectRef": "orv:subjectRef"
          }
        },

        "applicantBinding": {
          "@id": "orv:applicantBinding",
          "@context": {
            "@protected": true,
            "method": "orv:bindingMethod",
            "ref": "orv:bindingRef",
            "verifiedAt": {
              "@id": "orv:bindingVerifiedAt",
              "@type": "http://www.w3.org/2001/XMLSchema#dateTime"
            },
            "score": {
              "@id": "orv:bindingScore",
              "@type": "http://www.w3.org/2001/XMLSchema#double"
            }
          }
        },

        "person": {
          "@id": "orv:person",
          "@context": {
            "@protected": true,
            "fullName": "orv:fullName",
            "givenName": "orv:givenName",
            "familyName": "orv:familyName",
            "dateOfBirth": "orv:dateOfBirth",
            "gender": "orv:gender"
          }
        }
      }
    }
  }
}
