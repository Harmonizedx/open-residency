// OpenResidency data model.
// Deliberately minimal and privacy-preserving: the raw national ID is never stored.
// Only a tokenized subjectRef (HMAC of provider+id under a deployment pepper) is kept,
// so the residency register cannot be used to reconstruct foundational ID numbers.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resident {
  id              String   @id @default(uuid())
  residentId      String   @unique
  subjectRef      String   @unique
  countryCode     String
  subnationalUnit String
  providerCode    String
  assuranceLevel  String
  // Applicant -> identity binding: HOW the applicant was proven to own this identity.
  // A foundational match alone is not owner proof, so the method is recorded explicitly.
  bindingMethod   String   @default("none")
  bindingRef      String? // opaque: auth txn, biometric match id, or enrolment operator id
  bindingAt       DateTime?
  bindingScore    Float? // biometric match score, when the subsystem reports one
  // Proof of residence: the assurance level achieved for this resident in their unit, how
  // it was established, and the unit it is anchored to. A foundational residence field is
  // recorded as register_declared_residence, never as origin.
  residenceAssurance String @default("RAL0")
  residenceMethod    String @default("self_declared")
  residenceUnit      String?
  residenceAsOf      DateTime?
  provisional     Boolean  @default(false)
  credentialId    String?
  statusListIndex Int
  // Minimized demographic attributes carried into the credential.
  fullName        String?
  givenName       String?
  familyName      String?
  dateOfBirth     String?
  gender          String?
  phoneHash       String? // for USSD/OTP binding and matching; one-way, cannot be dialled
  // AES-256-GCM ciphertext of the E.164 number, under a key held outside the database
  // (CONTACT_ENCRYPTION_KEY). Present only when contactDirectory.mode is `encrypted`:
  // a one-way hash cannot be dialled, so actually delivering a one-time code needs the
  // number back in a recoverable form. A database dump yields ciphertext only.
  phoneEnc        String?
  createdAt       DateTime @default(now())

  @@index([countryCode, subnationalUnit])
}

// One growable revocation bitstring per country/deployment, plus a monotonic counter
// for assigning fresh status indices.
model StatusListState {
  countryCode String   @id
  encodedList String // gzip+base64url bitstring
  nextIndex   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

// A pending OpenID4VCI credential offer: the bridge between an enrollment desk and a
// citizen's wallet. Short-lived by design.
//
// The pre-authorized code and the transaction code are stored only as SHA-256 hashes.
// The raw code lives in the QR the citizen scans and nowhere else, so a dump of this
// table yields nothing that can be redeemed for a credential.
model CredentialOffer {
  id                    String    @id @default(uuid())
  preAuthorizedCodeHash String    @unique
  txCodeHash            String?
  residentId            String
  countryCode           String
  configurationIds      String[]
  expiresAt             DateTime
  redeemedAt            DateTime?
  // Wrong-PIN counter. A 6-digit tx_code is only safe if guesses are bounded.
  failedAttempts        Int       @default(0)
  createdAt             DateTime  @default(now())

  @@index([residentId])
  @@index([expiresAt])
}

// c_nonce values a wallet must sign over to prove key possession. Single-use: the unique
// primary key plus a delete-on-consume is what makes replay of a captured key proof fail.
model Oid4vciNonce {
  nonceHash String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// An in-flight OpenID4VP presentation request.
//
// Created by a relying party, answered by a wallet on a different connection, then polled
// for by the relying party -- three interactions that will not land on the same replica,
// which is why this is a table and not a map in memory.
//
// `status` is what makes a presentation single-use: the response endpoint only records an
// outcome while the request is still `pending`, so a captured vp_token replayed a second
// time cannot overwrite a verdict.
model PresentationRequest {
  id         String    @id @default(uuid())
  nonce      String    @unique
  clientId   String
  purpose    String
  reference  String?
  status     String    @default("pending")
  outcome    Json?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

// Short-lived one-time codes for the sign-in fallback factor (and Aadhaar-style flows).
//
// The code itself is stored only as a hash; the plaintext exists only in the delivered
// message. `failedAttempts` bounds brute force, because a 6-digit code is only safe if the
// number of guesses against it is limited.
model OtpChallenge {
  id             String   @id @default(uuid())
  residentId     String
  codeHash       String
  channel        String
  expiresAt      DateTime
  consumed       Boolean  @default(false)
  failedAttempts Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([residentId])
}

// Tamper-evident audit log. Each row is hash-chained to the previous (prevHash),
// so any later edit or deletion is detectable by recomputing the chain.
model AuditEvent {
  seq         Int      @id
  eventId     String   @unique
  timestamp   DateTime
  action      String
  actor       String
  target      String?
  countryCode String?
  outcome     String
  metadata    Json?
  prevHash    String
  hash        String

  @@index([target])
  @@index([action])
}

// A member of staff who may perform privileged actions.
//
// This exists so the audit log can name a person. Previously every privileged route was
// authenticated by one shared static API key, so an enrolment and a revocation both
// recorded the literal actor 'admin' and the log could not say who did either.
//
// Populated only when operatorAuth.mode is `local`. Under `oidc` the ministry's own
// directory is authoritative and a row here is optional -- used to add roles, or to
// disable an account locally as a kill switch that works even if IdP de-provisioning lags.
model Operator {
  id              String    @id @default(uuid())
  email           String    @unique
  displayName     String
  roles           String[]
  // scrypt$<salt>$<hash>. Null for operators that exist only to carry roles for an IdP
  // identity, which have no local password to steal.
  passwordHash    String?
  // Base32 TOTP secret. Confirmed on first successful use; once confirmed the second
  // factor is enforced regardless of the requireMfa setting.
  totpSecret      String?
  totpConfirmedAt DateTime?
  failedLogins    Int       @default(0)
  lockedUntil     DateTime?
  disabledAt      DateTime?
  createdAt       DateTime  @default(now())

  keys OperatorKey[]
}

// A long-lived credential for a machine caller (an enrolment kiosk, a batch job).
//
// Stored only as a SHA-256 hash, like every other credential here. `expiresAt` plus
// `rotatedFrom` are what make rotation real: two keys are valid at once during an overlap
// window, so callers move across one at a time instead of every client cutting over on a
// single restart -- which was the only option with the shared static key.
model OperatorKey {
  id         String    @id @default(uuid())
  operatorId String
  label      String
  keyHash    String    @unique
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  rotatedFrom String?
  createdAt  DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
}

// First-class consent records for cross-sector data sharing over SSO. Revocable,
// and each grant is backed by a signed, portable receipt (receiptId).
model ConsentRecord {
  id               String    @id
  subjectRef       String
  residentId       String
  relyingParty     String
  relyingPartyName String?
  purpose          String
  scopes           String[]
  status           String    @default("active")
  grantedAt        DateTime
  expiresAt        DateTime?
  revokedAt        DateTime?
  receiptId        String
  // The OIDC grant this consent authorizes, when created through the SSO consent step.
  // Revoking the consent revokes this grant and every token issued under it; without the
  // link the two stores drift and a withdrawn consent keeps releasing claims.
  grantId          String?

  @@index([residentId])
  @@index([relyingParty])
}
