// OpenResidency data model.
// Deliberately minimal and privacy-preserving: the raw national ID is never stored.
// Only a tokenized subjectRef (HMAC of provider+id under a deployment pepper) is kept,
// so the residency register cannot be used to reconstruct foundational ID numbers.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resident {
  id              String   @id @default(uuid())
  residentId      String   @unique
  subjectRef      String   @unique
  countryCode     String
  subnationalUnit String
  providerCode    String
  assuranceLevel  String
  provisional     Boolean  @default(false)
  credentialId    String?
  statusListIndex Int
  // Minimized demographic attributes carried into the credential.
  fullName        String?
  givenName       String?
  familyName      String?
  dateOfBirth     String?
  gender          String?
  phoneHash       String? // for USSD/OTP binding; hashed, never plaintext
  createdAt       DateTime @default(now())

  @@index([countryCode, subnationalUnit])
}

// One growable revocation bitstring per country/deployment, plus a monotonic counter
// for assigning fresh status indices.
model StatusListState {
  countryCode String   @id
  encodedList String // gzip+base64url bitstring
  nextIndex   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

// A pending OpenID4VCI credential offer: the bridge between an enrollment desk and a
// citizen's wallet. Short-lived by design.
//
// The pre-authorized code and the transaction code are stored only as SHA-256 hashes.
// The raw code lives in the QR the citizen scans and nowhere else, so a dump of this
// table yields nothing that can be redeemed for a credential.
model CredentialOffer {
  id                    String    @id @default(uuid())
  preAuthorizedCodeHash String    @unique
  txCodeHash            String?
  residentId            String
  countryCode           String
  configurationIds      String[]
  expiresAt             DateTime
  redeemedAt            DateTime?
  // Wrong-PIN counter. A 6-digit tx_code is only safe if guesses are bounded.
  failedAttempts        Int       @default(0)
  createdAt             DateTime  @default(now())

  @@index([residentId])
  @@index([expiresAt])
}

// c_nonce values a wallet must sign over to prove key possession. Single-use: the unique
// primary key plus a delete-on-consume is what makes replay of a captured key proof fail.
model Oid4vciNonce {
  nonceHash String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// An in-flight OpenID4VP presentation request.
//
// Created by a relying party, answered by a wallet on a different connection, then polled
// for by the relying party -- three interactions that will not land on the same replica,
// which is why this is a table and not a map in memory.
//
// `status` is what makes a presentation single-use: the response endpoint only records an
// outcome while the request is still `pending`, so a captured vp_token replayed a second
// time cannot overwrite a verdict.
model PresentationRequest {
  id         String    @id @default(uuid())
  nonce      String    @unique
  clientId   String
  purpose    String
  reference  String?
  status     String    @default("pending")
  outcome    Json?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

// Short-lived OTP challenges for USSD/SMS authentication and Aadhaar-style flows.
model OtpChallenge {
  id         String   @id @default(uuid())
  residentId String
  codeHash   String
  channel    String
  expiresAt  DateTime
  consumed   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([residentId])
}

// Tamper-evident audit log. Each row is hash-chained to the previous (prevHash),
// so any later edit or deletion is detectable by recomputing the chain.
model AuditEvent {
  seq         Int      @id
  eventId     String   @unique
  timestamp   DateTime
  action      String
  actor       String
  target      String?
  countryCode String?
  outcome     String
  metadata    Json?
  prevHash    String
  hash        String

  @@index([target])
  @@index([action])
}

// First-class consent records for cross-sector data sharing over SSO. Revocable,
// and each grant is backed by a signed, portable receipt (receiptId).
model ConsentRecord {
  id               String    @id
  subjectRef       String
  residentId       String
  relyingParty     String
  relyingPartyName String?
  purpose          String
  scopes           String[]
  status           String    @default("active")
  grantedAt        DateTime
  expiresAt        DateTime?
  revokedAt        DateTime?
  receiptId        String

  @@index([residentId])
  @@index([relyingParty])
}
