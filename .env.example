# OpenResidency environment.
#
# Copy to .env and adjust. The defaults here match docker-compose.yml, so
#   cp .env.example .env && docker compose up -d db && npm run prisma:migrate && npm run start:dev
# works with no edits for local development.
#
# NOTHING in this file is safe for production as-is. Every value marked "CHANGE IN
# PRODUCTION" is a development placeholder that must be replaced with a real secret,
# ideally injected from a secrets manager rather than a file on disk.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
# Matches the `db` service in docker-compose.yml. For a managed Postgres, replace
# the whole URL. The ?schema=public suffix is required by Prisma.
DATABASE_URL=postgresql://openres:openres@localhost:5432/openres?schema=public

# ---------------------------------------------------------------------------
# Service
# ---------------------------------------------------------------------------
# The public origin of this deployment. This is load-bearing: it is the OpenID4VCI
# Credential Issuer Identifier and the OpenID4VP client_id, so a wallet's key proof
# must name it in `aud`. If it is wrong, every proof is rejected as audience-mismatched.
# Must be the externally reachable URL in production (https://...), not localhost.
PUBLIC_BASE_URL=http://localhost:3000

# HTTP port the app listens on.
PORT=3000

# Per-route rate limit (requests per minute per client). Coarse edge limits belong in
# the ingress; this is the in-application backstop.
RATE_LIMIT_PER_MINUTE=120

# ---------------------------------------------------------------------------
# Secrets  (CHANGE IN PRODUCTION)
# ---------------------------------------------------------------------------
# Legacy shared admin key. Used ONLY when operatorAuth.mode is `sharedKey` (the default
# when a config declares no operatorAuth block). It carries no operator identity: every
# privileged action audits to the same actor, there are no roles, and rotating it means a
# restart with every client cutting over at once. Prefer operatorAuth.mode `oidc`.
ADMIN_API_KEY=dev-admin-key-change-me

# ---------------------------------------------------------------------------
# Operator accounts  (operatorAuth.mode: local)
# ---------------------------------------------------------------------------
# Creates the first admin operator on the boot where no operators exist yet, so there is
# a way in. The TOTP secret is printed to the log exactly once, on that boot -- enrol it
# in an authenticator app immediately, then remove these two variables.
# Not used when operatorAuth.mode is `oidc`: the ministry's directory owns accounts there.
# Commented out because the shipped demo config runs `sharedKey`. Uncomment these when
# you switch operatorAuth.mode to `local`.
# OPERATOR_BOOTSTRAP_EMAIL=admin@example.gov
# OPERATOR_BOOTSTRAP_PASSWORD=change-me-bootstrap-password

# ---------------------------------------------------------------------------
# Messaging  (see the `messaging` block in the country config)
# ---------------------------------------------------------------------------
# Set the pair your chosen aggregator needs. None are required with provider: LOG.
# AFRICASTALKING_API_KEY=
# TERMII_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SMS_GATEWAY_TOKEN=            # for a GENERIC_HTTP aggregator

# Encrypts residents' phone numbers at rest (contactDirectory.mode: encrypted). A one-way
# hash cannot be dialled, so delivering a code needs the number back in recoverable form;
# this key is what keeps a database dump from yielding a phone book. Generate with
# `openssl rand -hex 32` and hold it outside the database, ideally in a KMS. The app
# refuses to start in `encrypted` mode without it.
# CONTACT_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Foundational ID provider secrets
# ---------------------------------------------------------------------------
# Named by `foundational.auth.secretEnv` in each country config. A configured secret that
# is missing now fails loudly at the point of use rather than sending an empty header and
# surfacing the ministry gateway's 401 as an unexplained provider error.
# NIN_GATEWAY_KEY=              # config/countries/ng.yaml -- licensed NIMC gateway
# AADHAAR_API_TOKEN=            # config/countries/in.yaml
# XM_REGISTRY_API_KEY=          # config/countries/xm-xml.yaml

# Pepper for the one-way tokenization of foundational subject references. The raw
# national ID is never stored; only HMAC(provider+id, pepper) is. Rotating this pepper
# re-tokenizes everyone, so treat it as a long-lived secret and keep it out of logs.
SUBJECT_PEPPER=dev-pepper-change-me

# Signing key for OIDC session cookies. The app FAILS TO START if this is unset: a
# known cookie key lets anyone forge a session, and there is no safe degraded mode.
OIDC_COOKIE_SECRET=dev-cookie-secret-change-me

# Shared secret the USSD aggregator sends back on its webhook callbacks, as
# `x-ussd-secret` or `Authorization: Bearer`. The webhook takes the caller's word for
# `phoneNumber`, so it FAILS CLOSED if this is unset. If your aggregator signs its
# callbacks, verify that signature in UssdGatewayGuard instead of using a shared secret.
USSD_GATEWAY_SECRET=dev-ussd-secret-change-me

# ---------------------------------------------------------------------------
# Issuer signing key
# ---------------------------------------------------------------------------
# The Ed25519 private key that signs every credential, in JWK JSON on a single line.
# LEAVE UNSET in development: the app generates an ephemeral key on boot and logs a
# warning. In production this must be set (from a KMS/HSM export or a sealed secret),
# or credentials will not verify across restarts because the key changes each boot.
#
# ISSUER_PRIVATE_JWK={"kty":"OKP","crv":"Ed25519","d":"...","x":"..."}

# Key id advertised in credential headers and the DID document. Bump it when you rotate
# the key, so verifiers can distinguish old from new signatures.
ISSUER_KID=issuer-key-1

# The platform's own issuer DID (for the consent-receipt signer and OIDC). Defaults to
# the first country config's issuerDid if unset.
# PLATFORM_ISSUER_DID=did:web:id.katsina.gov.ng

# ---------------------------------------------------------------------------
# Paths (override only if you relocate these directories)
# ---------------------------------------------------------------------------
# Directory of country YAML configs. Defaults to ./config/countries.
# COUNTRY_CONFIG_DIR=./config/countries

# Directory of pinned JSON-LD contexts. Defaults to ./contexts. Canonicalization reads
# these from disk and refuses network fetches, so this directory must be present.
# CONTEXTS_DIR=./contexts

# ---------------------------------------------------------------------------
# Sector relying-party secrets (OIDC "Sign in with <State>")
# ---------------------------------------------------------------------------
# Each relying party defined under `relyingParties` in a country config reads its
# client secret from <CLIENT_ID>_CLIENT_SECRET (uppercased). The app FAILS TO START if
# any configured RP is missing its secret -- it used to fall back to a "<id>-dev-secret"
# placeholder derived from the public client id, which is guessable by anyone reading
# the source. The four below match the relying parties in config/countries/demo.yaml;
# add one line per RP you configure, and use real secrets in production.
HEALTH_CLIENT_SECRET=dev-health-secret-change-me
TAX_CLIENT_SECRET=dev-tax-secret-change-me
PERMITS_CLIENT_SECRET=dev-permits-secret-change-me
SUBSIDY_CLIENT_SECRET=dev-subsidy-secret-change-me
