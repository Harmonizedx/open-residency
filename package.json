{
  "name": "open-residency",
  "version": "0.1.0",
  "description": "Open-source, configurable subnational Residency ID and SSO platform. A Digital Public Good that binds any country's foundational identity API to a verifiable subnational residency credential, with offline-first inclusion and cross-sector single sign-on.",
  "license": "Apache-2.0",
  "author": "HarmonizedX Limited",
  "homepage": "https://github.com/harmonizedx/openresidency",
  "repository": {
    "type": "git",
    "url": "https://github.com/harmonizedx/openresidency.git"
  },
  "bugs": {
    "url": "https://github.com/harmonizedx/openresidency/issues"
  },
  "keywords": [
    "digital-public-good",
    "digital-identity",
    "verifiable-credentials",
    "residency",
    "openid-connect",
    "dpi"
  ],
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "smoke": "tsc -p tsconfig.core.json && node dist-core/scripts/smoke.js",
    "test": "jest",
    "smoke:oid4vci": "tsc -p tsconfig.core.json && node dist-core/scripts/oid4vci-smoke.js",
    "smoke:oid4vp": "tsc -p tsconfig.core.json && node dist-core/scripts/oid4vp-smoke.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.18.1",
    "express": "^5.2.1",
    "jose": "^5.10.0",
    "js-yaml": "^4.3.0",
    "jsonld": "^8.3.3",
    "oidc-provider": "^8.8.1",
    "qrcode": "^1.5.4",
    "rdf-canonize": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonld": "^1.5.15",
    "@types/node": "^22.20.1",
    "@types/oidc-provider": "^8.8.1",
    "@types/qrcode": "^1.5.6",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3"
  }
}
